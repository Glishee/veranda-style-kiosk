generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id           String    @id @default(cuid())
  slug         String    @unique
  order        Int
  translations Json      // { pl: { name }, en: { name }, de: { name } }
  products     Product[]
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  order        Int
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations Json     // { pl: { name, description }, en: { name, description }, de: { name, description } }
  imageUrl     String
}

model Lead {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  categorySlug String
  productSlug  String
  name         String
  phone        String
  city         String
  postcode     String
  comment      String?
  lang         String   @default("pl")
}
